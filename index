<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Porter Design - Kalkulator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/@supabase/supabase-js@2"></script>
</head>
<body class="bg-slate-50 p-4">
    <div class="max-w-md mx-auto bg-white rounded-2xl shadow-lg p-6 border-t-4 border-green-600">
        <h1 class="text-xl font-bold mb-4">PD Porter Design</h1>
        <div id="db-status" class="text-xs p-2 mb-4 rounded bg-gray-100 text-gray-500 text-center">
            Sprawdzanie połączenia z bazą...
        </div>
        <input type="number" id="w" class="w-full p-3 border rounded-xl mb-4" placeholder="Szerokość okna (cm)">
        <div id="output" class="text-sm space-y-2"></div>
    </div>

    <script>
        const supabaseUrl = 'https://rkcidwuszjvfwxszotnb.supabase.co';
        const supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJrY2lkd3Vzanp2Znd4c3pvdG5iIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ2MDU4NzIsImV4cCI6MjA5MDE4MTg3Mn0.N-frD06x0MzSg8dHmz-xneA16QvVrBmAYUg3ileNpXw';
        const _supabase = supabase.createClient(supabaseUrl, supabaseKey);

        async function init() {
            const { data, error } = await _supabase.from('fabrics').select('*').limit(5);
            const status = document.getElementById('db-status');
            if (error) {
                status.innerText = "Błąd bazy: " + error.message;
                status.className = "text-xs p-2 mb-4 rounded bg-red-100 text-red-600 text-center";
            } else {
                status.innerText = "Połączono z bazą tkanin ";
                status.className = "text-xs p-2 mb-4 rounded bg-green-100 text-green-700 text-center";
            }
        }
        init();
    </script>
</body>
</html>
